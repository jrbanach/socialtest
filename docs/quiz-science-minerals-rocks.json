    { "term": "mineral", "definition": "A naturally occurring, inorganic solid with a crystal structure and definite chemical composition" },
    { "term": "naturally occurring", "definition": "Made by Earth, not made by humans" },
    { "term": "inorganic", "definition": "Not made of living matter" },
    { "term": "crystal", "definition": "A regular repeating pattern of atoms" },
    { "term": "color", "definition": "A mineral property used to help identify a mineral by looking at it" },
    { "term": "luster", "definition": "The way a mineral's surface reflects light" },
    { "term": "metallic", "definition": "A type of luster that is shiny and metal-like" },
    { "term": "nonmetallic", "definition": "A type of luster that can be glassy, pearly, or waxy" },
    { "term": "streak", "definition": "The powder form of a mineral, tested by rubbing across a streak plate" },
    { "term": "streak plate", "definition": "Unglazed porcelain used to test a mineral's streak color" },
    { "term": "hardness", "definition": "A mineral's ability to resist being scratched" },
    { "term": "Mohs Hardness Scale", "definition": "A scale from 1 to 10 that ranks minerals by hardness, where 1 is softest and 10 is hardest" },
    { "term": "cleavage", "definition": "When a mineral breaks into flat, smooth sheets" },
    { "term": "fracture", "definition": "When a mineral breaks into jagged, rough pieces" },
    { "term": "rock", "definition": "A natural solid made of one or more minerals, classified by how it forms" },
    { "term": "igneous rock", "definition": "Rock that forms when molten material such as lava or magma cools and hardens" },
    { "term": "magma", "definition": "Melted rock found below Earth's surface" },
    { "term": "lava", "definition": "Melted rock found above Earth's surface" },
    { "term": "intrusive igneous rock", "definition": "Rock that forms under Earth's surface when magma cools slowly, creating large crystals" },
    { "term": "extrusive igneous rock", "definition": "Rock that forms above Earth's surface when lava cools quickly, creating small or no crystals" },
    { "term": "sedimentary rock", "definition": "Rock that forms when sediments are compacted and cemented together" },
    { "term": "weathering", "definition": "The process of breaking rock into smaller pieces called sediment" },
    { "term": "erosion", "definition": "The process of moving sediment from one place to another" },
    { "term": "deposition", "definition": "Laying sediment down in a new location where it settles out of water or wind" },
    { "term": "clastic", "definition": "A type of sedimentary rock formed from sediments compacted and cemented together" },
    { "term": "chemical sedimentary rock", "definition": "Rock that forms when mineral-rich water evaporates, leaving minerals behind" },
    { "term": "organic sedimentary rock", "definition": "Rock formed from the remains of living things compacted and cemented together" },
    { "term": "stalactite", "definition": "A formation that hangs down from the ceiling of a cavern" },
    { "term": "stalagmite", "definition": "A formation that builds up from the ground of a cavern" },
    { "term": "metamorphic rock", "definition": "Rock that forms when existing rock undergoes extreme heat and pressure" },
    { "term": "foliated", "definition": "A type of metamorphic rock where minerals band together to create stripes" },
    { "term": "nonfoliated", "definition": "A type of metamorphic rock where minerals are not arranged in stripes" },
    { "term": "rock cycle", "definition": "The continuous process in which one type of rock changes into another type of rock" },
    { "term": "silica", "definition": "A mineral component in igneous rocks; high silica makes light-colored rock and low silica makes dark-colored rock" }
